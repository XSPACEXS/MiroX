      "x": 1550,
      "y": 770,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#64B5F6", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r3_3",
      "type": "sticky_note",
      "content": "Measure growth: track skill assessments before/after each quarter. Make progress visible.",
      "x": 1820,
      "y": 770,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#64B5F6", "textAlign": "left", "fontSize": 10 }
