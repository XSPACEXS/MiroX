      "x": 2750,
      "y": 650,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#81C784", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_p1r2_3",
      "type": "sticky_note",
