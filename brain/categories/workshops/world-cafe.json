      "y": 620,
      "width": 200,
      "style": { "fontSize": 16, "fontWeight": "bold", "color": "#4A148C" }
    },
    {
      "id": "sticky_p1r2_1",
      "type": "sticky_note",
      "content": "Integrations are key. If we don't connect to Slack, GitHub, and Figma, we lose.",
