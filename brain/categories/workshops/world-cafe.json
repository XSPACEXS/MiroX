    },
    {
      "id": "sticky_g1r1_1",
      "type": "sticky_note",
      "content": "AI/ML literacy for all engineers — not just the ML team. Everyone should understand how our AI features work.",
      "x": 1280,
      "y": 530,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#BBDEFB", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r1_2",
      "type": "sticky_note",
      "content": "Annual learning budget ($2K/person) for courses, conferences, books.",
      "x": 1550,
      "y": 530,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#BBDEFB", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r1_3",
      "type": "sticky_note",
      "content": "Internal tech talks — monthly, by team members teaching each other.",
      "x": 1820,
      "y": 530,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#BBDEFB", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r1_4",
      "type": "sticky_note",
      "content": "Mentorship program: pair senior + junior across teams, not just within teams.",
      "x": 2090,
      "y": 530,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#BBDEFB", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "text_growth_r2",
      "type": "text",
      "content": "Round 2",
      "x": 1280,
      "y": 620,
      "width": 200,
      "style": { "fontSize": 16, "fontWeight": "bold", "color": "#4A148C" }
    },
    {
      "id": "sticky_g1r2_1",
      "type": "sticky_note",
      "content": "Career ladders need updating — the IC (individual contributor) track should go as high as the management track.",
      "x": 1280,
      "y": 650,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#90CAF9", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r2_2",
      "type": "sticky_note",
      "content": "Hackathon every quarter. Two days, cross-functional teams, ship something real.",
      "x": 1550,
      "y": 650,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#90CAF9", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r2_3",
      "type": "sticky_note",
      "content": "Skills that will matter: system design, AI prompting, data literacy, product thinking for engineers.",
      "x": 1820,
      "y": 650,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#90CAF9", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "sticky_g1r2_4",
      "type": "sticky_note",
      "content": "360 feedback twice a year (not just annual). More frequent input = better growth.",
      "x": 2090,
      "y": 650,
      "width": 250,
      "height": 70,
      "style": { "fillColor": "#90CAF9", "textAlign": "left", "fontSize": 10 }
    },
    {
      "id": "text_growth_r3",
      "type": "text",
      "content": "Round 3",
      "x": 1280,
      "y": 740,
      "width": 200,
