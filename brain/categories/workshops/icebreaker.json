    {
      "id": "sticky_fac1",
      "type": "sticky_note",
      "content": "Go first yourself to set the tone and show vulnerability. If you share something genuine, everyone else will too.",
      "x": 80,
      "y": 2070,
      "width": 500,
      "height": 70,
      "style": { "fillColor": "#CE93D8", "textAlign": "left", "fontSize": 11 }
    },
    {
      "id": "sticky_fac2",
      "type": "sticky_note",
      "content": "Keep it to 5-10 minutes max. Icebreakers should warm people up, not replace the meeting agenda.",
      "x": 600,
      "y": 2070,
      "width": 500,
      "height": 70,
      "style": { "fillColor": "#CE93D8", "textAlign": "left", "fontSize": 11 }
    },
    {
      "id": "sticky_fac3",
      "type": "sticky_note",
      "content": "Never force participation. 'Anyone want to share?' is better than going around the room in order. Some people need a moment.",
      "x": 1120,
      "y": 2070,
      "width": 500,
      "height": 70,
      "style": { "fillColor": "#CE93D8", "textAlign": "left", "fontSize": 11 }
    },
    {
      "id": "sticky_fac4",
      "type": "sticky_note",
      "content": "Avoid questions about family, relationships, or finances. Keep prompts universally comfortable and inclusive.",
