    {
      "id": "sticky_story1",
      "type": "sticky_note",
      "content": "US-1: As a PM, I want to see AI-suggested assignees on unassigned tasks so I can quickly assign work without checking everyone's calendar.",
      "x": 2530,
      "y": 420,
      "width": 700,
      "height": 80,
      "style": { "fillColor": "#E8F5E9", "textAlign": "left", "fontSize": 11 }
    },
    {
      "id": "sticky_story2",
      "type": "sticky_note",
      "content": "US-2: As a PM, I want to approve or dismiss AI suggestions with one click so the workflow stays fast and non-disruptive.",
      "x": 3280,
      "y": 420,
      "width": 700,
      "height": 80,
      "style": { "fillColor": "#E8F5E9", "textAlign": "left", "fontSize": 11 }
    },
    {
      "id": "sticky_story3",
      "type": "sticky_note",
      "content": "US-3: As an engineer, I want to see why I was suggested (skill match, capacity) so I can understand and trust the system.",
